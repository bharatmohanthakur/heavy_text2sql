# Secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key

# Ed-Fi cached artifacts (large; rebuilt on demand). The directory itself
# is tracked (so the path resolves on a fresh clone) but its contents are
# ignored — except the canned zero-infra demo target, which we ship so
# `git clone` + `text2sql serve` works without an operator-supplied DB
# (regenerable via `python scripts/build_sample_demo_sqlite.py`).
data/edfi/*
!data/edfi/sample_demo.sqlite
data/artifacts/
data/eval/frozen_db.sql

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
dist/
build/
*.egg

# Node
node_modules/
.next/
out/

# Editors
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Local env / runtime
*.log
.coverage
htmlcov/

# Provider routing is in configs/default.yaml; secrets live here.
# Copy to .env and fill in. .env is gitignored.

# ─── Azure OpenAI (default LLM + embeddings) ──────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ─── Anthropic (alternate LLM) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── OpenAI direct (alternate LLM + embeddings) ───────────────────────────────
OPENAI_API_KEY=

# ─── AWS Bedrock (alternate LLM + Titan embeddings) ───────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─── Target SQL engine ────────────────────────────────────────────────────────
# Local Postgres (default for dev; matches Ed-Fi populated docker image)
TARGET_DB_DIALECT=postgresql
TARGET_DB_HOST=127.0.0.1
TARGET_DB_PORT=5432
TARGET_DB_NAME=EdFi_Ods
TARGET_DB_USER=edfi
TARGET_DB_PASSWORD=edfi

# Azure SQL / MSSQL alternate — uncomment & set TARGET_DB_DIALECT=mssql
# TARGET_DB_DIALECT=mssql
# TARGET_DB_HOST=YOUR-SERVER.database.windows.net
# TARGET_DB_PORT=1433
# TARGET_DB_NAME=YOUR-DB
# TARGET_DB_USER=
# TARGET_DB_PASSWORD=
# TARGET_DB_TRUST_SERVER_CERTIFICATE=true

# ─── Metadata DB (gold SQL, users, audit) — always Postgres ───────────────────
METADATA_DB_HOST=127.0.0.1
METADATA_DB_PORT=5432
METADATA_DB_NAME=text2sql_meta
METADATA_DB_USER=edfi
METADATA_DB_PASSWORD=edfi

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
